# Docker
# https://github.com/ohmyzsh/ohmyzsh/tree/master/plugins/docker
alias dnames="docker ps --format '{{.Names}}'"

function dip {
  local OUT=""
  local IP=""
  local NAME=""
  for NAME in $(docker ps --format '{{.Names}}')
  do
    IP=$(docker inspect --format='{{range .NetworkSettings.Networks}}{{println .IPAddress}}{{end}}' "${NAME}" | xargs)
    if [ -n "$IP" ]; then
      OUT+="${NAME}\t${IP}\n"
    else
      OUT+="${NAME}\t(none)\n"
    fi
  done
  echo -e "${OUT}" | column -t
}

